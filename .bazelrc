# configflux-cortex build configuration.

startup --max_idle_secs=60

# Bzlmod only
common --noenable_workspace
common --enable_bzlmod

# Reproducibility and stable logs
build --incompatible_strict_action_env
common --color=yes
common --curses=auto
build --show_result=2

build --remote_download_outputs=toplevel

# Sandboxing defaults (no NpmLifecycleHook — Python only)
build --spawn_strategy=sandboxed
build --strategy=CopyFile=sandboxed,standalone
build --strategy=CopyToDirectory=sandboxed,standalone
build --sandbox_default_allow_network=false

# Test behavior
test --test_output=errors
test --strategy=TestRunner=sandboxed,standalone

# CI: skip tests that need devcontainer-only tools
test:ci --test_tag_filters=-no-ci

# Local developer overrides (gitignored)
try-import %workspace%/.bazelrc.local
